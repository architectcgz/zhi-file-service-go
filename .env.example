# zhi-file-service-go 环境变量示例文件
# 所有配置项以 configuration-registry-spec.md 为权威来源
# 标注 [SECRET] 的配置项禁止写入 Git，必须通过 Kubernetes Secret 或外部密钥管理注入
# 标注 [REQUIRED] 的配置项没有安全默认值，必须在启动前显式设置

# ============================================================
# 应用级（所有服务共享）
# ============================================================

# 运行环境：dev | test | staging | prod
APP_ENV=dev

# 服务名，每个服务启动时覆盖（upload-service / access-service / admin-service / job-service）
# [REQUIRED]
APP_SERVICE_NAME=upload-service

# 日志级别：debug | info | warn | error
APP_LOG_LEVEL=info

# 优雅停机超时
APP_SHUTDOWN_TIMEOUT=15s

# ============================================================
# HTTP 服务
# ============================================================

HTTP_PORT=8080
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s

# ============================================================
# 数据库（PostgreSQL）
# ============================================================

# [REQUIRED] [SECRET] PostgreSQL DSN，禁止写入 Git
# 示例格式：postgres://user:password@host:5432/dbname?sslmode=disable
DB_DSN=postgres://zhi:zhi@localhost:5432/zhi_file_service?sslmode=disable

DB_MAX_OPEN_CONNS=50
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=30m

# ============================================================
# Redis
# ============================================================

# upload-service 和 job-service 需要 Redis；access-service 可选用于缓存
REDIS_ADDR=localhost:6379

# [SECRET] Redis 密码，无密码时留空
# REDIS_PASSWORD=

REDIS_DB=0

# ============================================================
# 对象存储（S3 / MinIO）
# ============================================================

# [REQUIRED] S3 兼容存储 endpoint（本地开发使用 MinIO）
STORAGE_ENDPOINT=http://localhost:9000

STORAGE_REGION=us-east-1

# [REQUIRED] [SECRET] 存储 access key，禁止写入 Git
STORAGE_ACCESS_KEY=minioadmin

# [REQUIRED] [SECRET] 存储 secret key，禁止写入 Git
STORAGE_SECRET_KEY=minioadmin

# [REQUIRED] public bucket 名称
STORAGE_PUBLIC_BUCKET=zhi-files-public

# [REQUIRED] private bucket 名称
STORAGE_PRIVATE_BUCKET=zhi-files-private

# public 对象的基础 URL 前缀（CDN 或 public bucket base URL），留空则由 endpoint 推导
STORAGE_PUBLIC_BASE_URL=

# S3 path style 开关（MinIO 本地开发必须为 true）
STORAGE_FORCE_PATH_STYLE=true

# ============================================================
# 可观测性（OpenTelemetry）
# ============================================================

# OTLP 上报地址（留空则不上报 trace）
OTEL_ENDPOINT=

# 服务版本号，建议注入 Git commit SHA 或 release tag
OTEL_SERVICE_VERSION=dev

# Prometheus metrics 开关
METRICS_ENABLED=true

# ============================================================
# upload-service 专属配置
# ============================================================

# 代理上传（INLINE 模式）的最大文件大小，单位 byte（默认 10MB）
UPLOAD_MAX_INLINE_SIZE=10485760

# 上传会话存活时间
UPLOAD_SESSION_TTL=24h

# complete 内部超时
UPLOAD_COMPLETE_TIMEOUT=30s

# presigned URL 过期时间
UPLOAD_PRESIGN_TTL=15m

# 允许的上传模式（逗号分隔）
UPLOAD_ALLOWED_MODES=INLINE,PRESIGNED_SINGLE,DIRECT

# ============================================================
# access-service 专属配置
# ============================================================

# [REQUIRED] [SECRET] 访问票据签名密钥，禁止写入 Git
# ACCESS_TICKET_SIGNING_KEY=

# 访问票据 TTL
ACCESS_TICKET_TTL=5m

# 下载跳转地址 TTL
ACCESS_DOWNLOAD_REDIRECT_TTL=2m

# public 文件是否生成 public URL（false 则始终走 presign）
ACCESS_PUBLIC_URL_ENABLED=true

# private 文件 presign GET URL TTL
ACCESS_PRIVATE_PRESIGN_TTL=2m

# ============================================================
# admin-service 专属配置
# ============================================================

# [REQUIRED] [SECRET] 管理面认证 JWKS（JSON 内容或 JWKS URL），禁止写入 Git
# ADMIN_AUTH_JWKS=

# 后台文件/租户删除是否强制传 reason 字段
ADMIN_DELETE_REQUIRES_REASON=true

# 列表接口默认分页大小
ADMIN_LIST_DEFAULT_LIMIT=50

# 列表接口最大分页大小
ADMIN_LIST_MAX_LIMIT=200

# ============================================================
# job-service 专属配置
# ============================================================

# 是否启用调度器主循环
JOB_SCHEDULER_ENABLED=true

# 任务默认批处理大小
JOB_DEFAULT_BATCH_SIZE=100

# 任务默认并发数
JOB_DEFAULT_MAX_CONCURRENCY=4

# 分布式锁后端（当前仅支持 redis）
JOB_LOCK_BACKEND=redis

# 分布式锁 TTL
JOB_LOCK_TTL=30s

# 分布式锁续租间隔
JOB_LOCK_RENEW_INTERVAL=10s

# 过期上传会话清理间隔
JOB_EXPIRE_UPLOAD_SESSIONS_INTERVAL=5m

# stuck COMPLETING 会话修复间隔
JOB_REPAIR_STUCK_COMPLETING_INTERVAL=2m

# 文件物理删除间隔
JOB_FINALIZE_FILE_DELETE_INTERVAL=1m

# 孤儿 blob 清理间隔
JOB_CLEANUP_ORPHAN_BLOBS_INTERVAL=10m

# 租户使用量对账间隔
JOB_RECONCILE_TENANT_USAGE_INTERVAL=30m
